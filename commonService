  @Override
  public CompetencyMgmtResponseObject<List<CompetencyModel>> findCompetencyByIds(
      RequestContext requestContext, List<Long> ids) {
    log.info("Got the request to find list of competencies by id. Request Context: {}, Ids: {}",
        requestContext, ids);
    CompetencyMgmtResponseObject<List<CompetencyModel>> responseObject =
        new CompetencyMgmtResponseObject<>(PROCESSING_ERROR);
    List<Competency> competencies =
        competencyService.findByCustomerIdAndIdIn(requestContext.getCustomerId(), ids);
    if (CollectionUtils.isEmpty(competencies)) {
      responseObject.setStatus(DATA_VALIDATION_FAILED);
    } else {
      responseObject.setStatus(SUCCESS);
      responseObject.setResponseObject(competencies.stream().map(
              competency -> new CompetencyModel(competency.getId(),
                  competency.getCompetencyGroupId(),
                  competency.getCompetencyName(), competency.getFeedbackQuestionScale()))
          .collect(Collectors.toList()));
    }
    logResponseInDebug(responseObject.getResponseObject(), responseObject.getStatus());
    return responseObject;
  }

  @Override
  public CompetencyMgmtResponseObject<CompetencyGroupModel> upsertCompetencyGroup(
      RequestContext requestContext, CompetencyGroupModel competencyGroupModel) {
    log.info(
        "Got the request to Upsert the Competency Group. Request Context: {}, "
            + "CompetencyGroupModel: {}",
        requestContext, competencyGroupModel);
    CompetencyMgmtResponseObject<CompetencyGroupModel> responseObject =
        new CompetencyMgmtResponseObject<>(PROCESSING_ERROR);

    if (null != competencyGroupModel && StringUtils
        .isNotEmpty(competencyGroupModel.getGroupName())) {

      CompetencyGroup existingGroup = competencyGroupService
          .findByCustomerIdAndGroupName(requestContext.getCustomerId(),
              competencyGroupModel.getGroupName());

      log.info(
          "Competency Group Found with the name. RequestContext: {}, Group Name:{}, Groups Found:"
              + " {}",
          requestContext, competencyGroupModel.getGroupName(), existingGroup);
      if (Objects.isNull(existingGroup)) {
        CompetencyGroup competencyGroup = null;
        if (null == competencyGroupModel.getId()) {
          competencyGroup = CompetencyGroup.builder().customerId(requestContext.getCustomerId())
              .groupName(competencyGroupModel.getGroupName())
              .createdBy(requestContext.getSignedInUserId())
              .createdOn(DateTimeUtility.getCurrentTimestampInUTC())
              .updatedBy(requestContext.getSignedInUserId())
              .updatedOn(DateTimeUtility.getCurrentTimestampInUTC()).build();

        } else {
          competencyGroup = competencyGroupService
              .findByCustomerIdAndId(requestContext.getCustomerId(), competencyGroupModel.getId());
          competencyGroup.setGroupName(competencyGroupModel.getGroupName());
        }
        competencyGroup = competencyGroupService.save(competencyGroup);
        competencyGroupModel.setId(competencyGroup.getId());
        responseObject.setStatus(SUCCESS);
      } else {
        competencyGroupModel.setId(existingGroup.getId());
        responseObject.setStatus(DUPLICATE_COMPETENCY_GROUP_NAME);
      }
    }

    responseObject.setResponseObject(competencyGroupModel);
    return responseObject;
  }

