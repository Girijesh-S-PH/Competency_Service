  private void filterCompetencyStatusAndCountMap(
      Map<CompetencyStatus, Long> competencyStatusAndCountMap) {
    if (MapUtils.isEmpty(competencyStatusAndCountMap)) {
      competencyStatusAndCountMap.put(CompetencyStatus.ACTIVE, 0L);
      competencyStatusAndCountMap.put(CompetencyStatus.DRAFT, 0L);
    } else {
      if (!competencyStatusAndCountMap.containsKey(CompetencyStatus.ACTIVE)) {
        competencyStatusAndCountMap.put(CompetencyStatus.ACTIVE, 0L);
      }
      if (!competencyStatusAndCountMap.containsKey(CompetencyStatus.DRAFT)) {
        competencyStatusAndCountMap.put(CompetencyStatus.DRAFT, 0L);
      }
    }
  }

  private CompetencyManagementStatusCode validateAssignCompetencyModel(
      RequestContext requestContext, List<CompetencyApplicability> competencyApplicabilities,
      AssignCompetencyModel assignCompetencyModel) {
    CompetencyManagementStatusCode statusCode = SUCCESS;
    Map<Long, List<ApplicabilityModel>> competencyApplicabilityModel = new HashMap<>();
    List<ApplicabilityModel> applicabilityModels =
        modelAdapter.constructCompetencyApplicabilityFromListOfEntities(requestContext,
            competencyApplicabilities, Collections.EMPTY_MAP, Collections.EMPTY_MAP);
    assignCompetencyModel.getAssignedCompetencies().forEach(assignedCompetency -> {
      applicabilityModels.add(ApplicabilityModel.builder()
          .payGradeIds(Arrays.asList(assignCompetencyModel.getPayGradeId()))
          .jobFunctionId(assignCompetencyModel.getJobFunctionId())
          .competencyId(assignedCompetency.getCompetencyId()).editStatus(EditStatus.ADDED)
          .weightage(assignedCompetency.getWeightage()).build());
    });
    applicabilityModels.forEach(applicabilityModel -> {
      List<ApplicabilityModel> applicabilityModelList = competencyApplicabilityModel
          .getOrDefault(applicabilityModel.getCompetencyId(), new ArrayList<>());
      applicabilityModelList.add(applicabilityModel);
      competencyApplicabilityModel
          .put(applicabilityModel.getCompetencyId(), applicabilityModelList);
    });
    for (Map.Entry<Long, List<ApplicabilityModel>> entry : competencyApplicabilityModel
        .entrySet()) {
      statusCode = ValidationUtility.getApplicabilityValidation(entry.getValue());
      if (!SUCCESS.equals(statusCode)) {
        break;
      }
    }
    return statusCode;
  }

  private void constructCompetencyAndApplicability(AssignCompetencyModel finalAssignCompetencyModel,
      RequestContext requestContext, List<CompetencyApplicability> competencyApplicabilityToSave,
      List<CompetencyPaygrade> competencyPaygradesToSave) {
    finalAssignCompetencyModel.getAssignedCompetencies().forEach(competencyWeightage -> {
      competencyPaygradesToSave.add(
          CompetencyPaygrade.builder().customerId(requestContext.getSignedInCustomerId())
              .payGradeIds(finalAssignCompetencyModel.getPayGradeId())
              .createdBy(requestContext.getSignedInUserId())
              .createdOn(DateTimeUtility.getCurrentTimestampInUTC()).build());
      competencyApplicabilityToSave.add(
          CompetencyApplicability.builder().customerId(requestContext.getSignedInCustomerId())
              .competencyId(competencyWeightage.getCompetencyId())
              .jobFunctionId(finalAssignCompetencyModel.getJobFunctionId())
              .weightage(competencyWeightage.getWeightage())
              .createdBy(requestContext.getSignedInUserId())
              .createdOn(DateTimeUtility.getCurrentTimestampInUTC()).build());
    });
  }
