  private void upsertRatingQuestions(CompetencyModel competencyModel,
      RequestContext requestContext) {
    List<RatingQuestionModel> ratingQuestionModels = competencyModel.getRatingQuestionModels();
    if (CollectionUtils.isNotEmpty(ratingQuestionModels)) {
      Map<Long, RatingQuestionModel> ratingQuestionModelMap = new HashMap<>();
      List<RatingQuestion> ratingQuestions = new ArrayList<>(ratingQuestionModels.size());
      for (RatingQuestionModel ratingQuestionModel : ratingQuestionModels) {
        ratingQuestionModel.setCustomerId(competencyModel.getCustomerId());
        ratingQuestionModel.setCompetencyId(competencyModel.getId());
        if (null != ratingQuestionModel.getId()) {
          ratingQuestionModelMap.put(ratingQuestionModel.getId(), ratingQuestionModel);
        } else {
          ratingQuestions.add(modelAdapter
              .getEntityFromRatingQuestionModel(ratingQuestionModel, null, requestContext));
        }
      }
      if (MapUtils.isNotEmpty(ratingQuestionModelMap)) {
        List<Long> ratingQuestionsToNotDelete = new ArrayList<>();
        List<RatingQuestion> ratingQuestionList = ratingQuestionService
            .findByCustomerIdAndIdIn(requestContext.getCustomerId(),
                ratingQuestionModelMap.keySet());
        ratingQuestionList.forEach(ratingQuestion -> {
          if (null != ratingQuestion.getId()) {
            ratingQuestionsToNotDelete.add(ratingQuestion.getId());
          }
          ratingQuestions.add(modelAdapter
              .getEntityFromRatingQuestionModel(ratingQuestionModelMap.get(ratingQuestion.getId()),
                  ratingQuestion, requestContext));
        });
        if (CollectionUtils.isNotEmpty(ratingQuestionsToNotDelete)) {
          ratingQuestionService
              .deleteByCustomerIdAndCompetencyIdAndIdNotIn(requestContext.getCustomerId(),
                  competencyModel.getId(), ratingQuestionsToNotDelete);
        }
      } else {
        ratingQuestionService.deleteByCustomerIdAndCompetencyId(requestContext.getCustomerId(),
            competencyModel.getId());
      }
      ratingQuestionService.saveAll(ratingQuestions);
    }
  }

  private void upsertCompetencyApplicability(Long competencyId,
      List<ApplicabilityModel> applicabilityModels, RequestContext requestContext) {
    if (CollectionUtils.isEmpty(applicabilityModels)) {
      return;
    }
    List<CompetencyApplicability> applicabilitiesToAdd = new ArrayList<>();
    List<Long> competenciesToDelete = new ArrayList<>();
    List<Long> competenciesToEdit = new ArrayList<>();
    Map<Long, ApplicabilityModel> applicabilityModelMap = new HashMap<>();
    applicabilityModels.forEach(applicabilityModel -> {
      if (null == applicabilityModel.getEditStatus()) {
        return;
      }
      switch (applicabilityModel.getEditStatus()) {
        case ADDED:
          applicabilityModel.setCompetencyId(competencyId);
          CompetencyApplicability applicability = (modelAdapter
              .getEntityFromCompetencyApplicabilityModel(applicabilityModel, null, requestContext));

          List<Long> payGradeIds = applicabilityModel.getPayGradeIds();
          if (CollectionUtils.isNotEmpty(payGradeIds)) {
            List<CompetencyPaygrade> competencyPaygrades = new ArrayList<>();
            payGradeIds.forEach(payGradeId -> competencyPaygrades.add(
                CompetencyPaygrade.builder().customerId(requestContext.getCustomerId())
                    .payGradeIds(payGradeId).createdBy(requestContext.getSignedInUserId())
                    .createdOn(DateTimeUtility.getCurrentTimestampInUTC()).build()));
            applicability.setApplicabilityPaygrade(competencyPaygrades);
          }
          applicabilitiesToAdd.add(applicability);
          break;
        case EDITED:
          Long id = applicabilityModel.getId();
          competenciesToEdit.add(id);
          applicabilityModelMap.put(id, applicabilityModel);
          break;
        case DELETED:
          competenciesToDelete.add(applicabilityModel.getId());
          break;
        case SAVED:
          break;
      }
    });

    if (CollectionUtils.isNotEmpty(competenciesToDelete)) {
      competencyPaygradeService
          .deleteByCustomerIdAndCompetencyApplicabilityIdIn(requestContext.getCustomerId(),
              competenciesToDelete);
      competencyApplicabilityService
          .deleteByCustomerIdAndIdIn(requestContext.getCustomerId(), competenciesToDelete);
    }
    List<CompetencyPaygrade> competencyPaygrades = new ArrayList<>();
    List<CompetencyApplicability> applicabilitiesToEdit =
        new ArrayList<>(competenciesToEdit.size());
    if (CollectionUtils.isNotEmpty(competenciesToEdit)) {
      competencyPaygradeService
          .deleteByCustomerIdAndCompetencyApplicabilityIdIn(requestContext.getCustomerId(),
              competenciesToEdit);
      List<CompetencyApplicability> applicabilityEntities = competencyApplicabilityService
          .findByCustomerIdAndIdIn(requestContext.getCustomerId(), competenciesToEdit);
      applicabilityEntities.forEach(applicabilityEntity -> {
        CompetencyApplicability applicability = modelAdapter
            .getEntityFromCompetencyApplicabilityModel(
                applicabilityModelMap.get(applicabilityEntity.getId()), applicabilityEntity,
                requestContext);
        applicability.setApplicabilityPaygrade(null);
        applicabilitiesToEdit.add(applicability);
        ApplicabilityModel payGradeModels = applicabilityModelMap.get(applicabilityEntity.getId());
        if (null != payGradeModels && CollectionUtils.isNotEmpty(payGradeModels.getPayGradeIds())) {
          payGradeModels.getPayGradeIds().forEach(payGradeIds -> competencyPaygrades.add(
              CompetencyPaygrade.builder().customerId(applicabilityEntity.getCustomerId())
                  .payGradeIds(payGradeIds).competencyApplicabilityId(applicabilityEntity.getId())
                  .createdBy(requestContext.getSignedInUserId())
                  .createdOn(DateTimeUtility.getCurrentTimestampInUTC())
                  .id(applicabilityEntity.getId()).updatedBy(requestContext.getSignedInUserId())
                  .updatedOn(DateTimeUtility.getCurrentTimestampInUTC()).build()));
        }
      });
    }

    if (CollectionUtils.isNotEmpty(applicabilitiesToEdit)) {
      competencyApplicabilityService.saveAll(applicabilitiesToEdit);
    }

    if (CollectionUtils.isNotEmpty(applicabilitiesToAdd)) {
      for (CompetencyApplicability competencyApplicability : applicabilitiesToAdd) {
        CompetencyApplicability applicabilityEntity =
            competencyApplicabilityService.save(competencyApplicability);
        competencyApplicability.getApplicabilityPaygrade().forEach(paygrade -> {
          paygrade.setCompetencyApplicabilityId(applicabilityEntity.getId());
          competencyPaygrades.add(paygrade);
        });
      }
    }

    if (CollectionUtils.isNotEmpty(competencyPaygrades)) {
      competencyPaygradeService.saveAll(competencyPaygrades);
    }
  }

  @Override
  public CompetencyMgmtResponseObject<CompetencySnapshotModel> getCompetencySnapshot(
      RequestContext requestContext, Map<String, String> additionalParam) {
    log.info("Getting the Competency Snapshot. Request Context: {}, Additional Params: {}",
        requestContext, additionalParam);
    CompetencyMgmtResponseObject<CompetencySnapshotModel> responseObject =
        new CompetencyMgmtResponseObject<>(PROCESSING_ERROR);
    List<Competency> competencies =
        competencyService.findAllByCustomerIdAndStatus(requestContext.getCustomerId(),
            CompetencyStatus.ACTIVE);
    CompetencySnapshotModel competencySnapshotModel =
        modelAdapter.getBasicCompetencySnapshotModel(additionalParam);
    if (CollectionUtils.isEmpty(competencies)) {
      responseObject.setStatus(SUCCESS);
      responseObject.setResponseObject(competencySnapshotModel);
    } else {

      Map<String, List<Competency>> applicableCompetencyMap = new HashMap<>();
      Map<String, Double> competencyApplicabilityWeightageMap = new HashMap<>();
      competencies.forEach(competency -> {
        List<CompetencyApplicability> applicabilityList =
            competency.getCompetencyApplicabilityList();
        if (CollectionUtils.isNotEmpty(applicabilityList)) {
          applicabilityList.forEach(competencyApplicability -> {
            Long jobFunctionId = competencyApplicability.getJobFunctionId();
            List<Long> payGradeIds = Collections.EMPTY_LIST;
            if (CollectionUtils.isNotEmpty(competencyApplicability.getApplicabilityPaygrade())) {
              payGradeIds = competencyApplicability.getApplicabilityPaygrade().stream()
                  .map(CompetencyPaygrade::getPayGradeIds).collect(Collectors.toList());
            }
            payGradeIds.forEach(payGradeId -> {
              String mapKey = applicableCompetencyKey(jobFunctionId, payGradeId);
              List<Competency> competencyList =
                  applicableCompetencyMap.getOrDefault(mapKey, new ArrayList<>());
              competencyList.add(competency);
              applicableCompetencyMap.put(mapKey, competencyList);
              competencyApplicabilityWeightageMap.put(
                  new StringBuilder().append(mapKey).append(UNDERSCORE).append(competency.getId())
                      .toString(), competencyApplicability.getWeightage());
            });
          });
        }
      });

      Map<Long, String> competencyGroupNameMap = new HashMap<>();
      List<CompetencyGroup> competencyGroups =
          competencyGroupService.findAllByCustomerId(requestContext.getCustomerId());
      if (CollectionUtils.isNotEmpty(competencyGroups)) {
        competencyGroupNameMap = competencyGroups.stream()
            .collect(Collectors.toMap(CompetencyGroup::getId, CompetencyGroup::getGroupName));
      }
      List<RatingQuestion> ratingQuestions =
          ratingQuestionService.findByCustomerId(requestContext.getCustomerId());
      Map<Long, List<RatingQuestionModel>> competencyRatingQuestionMap = new HashMap<>();
      if (CollectionUtils.isNotEmpty(ratingQuestions)) {
        for (RatingQuestion ratingQuestion : ratingQuestions) {
          List<RatingQuestionModel> ratingQuestionModels = competencyRatingQuestionMap
              .getOrDefault(ratingQuestion.getCompetencyId(), new ArrayList<>());
          ratingQuestionModels.add(modelAdapter.constructRatingQuestionFromEntity(ratingQuestion));
          competencyRatingQuestionMap.put(ratingQuestion.getCompetencyId(), ratingQuestionModels);
        }
      }

      List<TestSetting> testSettings =
          testSettingsService.findByCustomerId(requestContext.getCustomerId());
      Map<Long, TestSettingsModel> competencyTestSettingModel = new HashMap<>();
      if (CollectionUtils.isNotEmpty(testSettings)) {
        testSettings.forEach(testSetting -> competencyTestSettingModel
            .put(testSetting.getCompetencyId(),
                modelAdapter.constructTestSettingModelFromEntity(testSetting)));
      }
      if (MapUtils.isNotEmpty(applicableCompetencyMap)) {
        List<CompetencySnapshot> competencySnapshots = new ArrayList<>();
        for (Map.Entry<String, List<Competency>> entry : applicableCompetencyMap.entrySet()) {
          String[] keys = entry.getKey().split(UNDERSCORE);
          Long jobFunctionId = Long.valueOf(keys[0]);
          Long payGradeId = Long.valueOf(keys[1]);
          ApplicabilityType paygradeApplicabilityType = ApplicabilityType.CUSTOM;
          if (LONG_ZERO.equals(payGradeId)) {
            paygradeApplicabilityType = ApplicabilityType.ALL;
          }
          ApplicabilityType jobFunctionApplicabilityType = ApplicabilityType.CUSTOM;
          if (LONG_ZERO.equals(jobFunctionId)) {
            jobFunctionApplicabilityType = ApplicabilityType.ALL;
          }
          CompetencySnapshot snapshot =
              CompetencySnapshot.builder().jobFunctionId(jobFunctionId).payGradeId(payGradeId)
                  .applicableJobFunction(jobFunctionApplicabilityType)
                  .applicablePayGradeLevel(paygradeApplicabilityType).build();

          snapshot.setApplicableCompetency(modelAdapter.getCompetencyModelListFromEntityList(
              applicableCompetencyKey(jobFunctionId, payGradeId), entry.getValue(),
              competencyGroupNameMap, competencyApplicabilityWeightageMap,
              competencyRatingQuestionMap, competencyTestSettingModel));

          competencySnapshots.add(snapshot);
        }

        competencySnapshotModel.setCompetencySnapshot(competencySnapshots);
      }
      responseObject.setResponseObject(competencySnapshotModel);
      responseObject.setStatus(SUCCESS);
    }
    logResponseInDebug(responseObject.getResponseObject(), responseObject.getStatus());
    return responseObject;
  }

  private String applicableCompetencyKey(Long jobFunctionId, Long paygradeId) {
    return new StringBuilder().append(jobFunctionId).append(UNDERSCORE).append(paygradeId)
        .toString();
  }

  @Override
  public CompetencyMgmtResponseObject<CompetencyModel> findCompetencyById(
      RequestContext requestContext, Long competencyId) {
    CompetencyMgmtResponseObject<CompetencyModel> responseObject =
        new CompetencyMgmtResponseObject<>(PROCESSING_ERROR);
    Competency competency =
        competencyService.findByCustomerIdAndId(requestContext.getCustomerId(), competencyId);
    if (null == competency) {
      responseObject.setStatus(INVALID_CUSTOMER_SCOPE);
    } else {

      CompetencyModel competencyModel = modelAdapter.getBasicCompetencyModelFromEntity(competency);

      competencyModel.setCompetencyGroupName(
          getCompetencyGroupName(requestContext, competency.getCompetencyGroupId()));
      List<UserModel> auditUserModels = onboardingRestUtility.getBasicUserInfoList(requestContext,
          Arrays.asList(competency.getUpdatedBy(), competency.getCreatedBy()), true);

      if (CollectionUtils.isNotEmpty(auditUserModels)) {
        auditUserModels.forEach(userModel -> {
          BasicIdentityModel identityModel = new BasicIdentityModel();
          genericUtility.setBasicIdentityModel(identityModel, userModel);
          if (competency.getUpdatedBy().equals(userModel.getUserId())) {
            competencyModel.setModifiedBy(identityModel);
          }
          if (competency.getCreatedBy().equals(userModel.getUserId())) {
            competencyModel.setCreatedBy(identityModel);
          }
        });
      }

      Map<Long, PayGradeModel> configuredPaygradeMap =
          getPayGradeConfiguredForCustomer(requestContext);
      Map<Long, JobFunction> configuredJobFunctions = getJobFunctionsForCustomer(requestContext);
      competencyModel.setCompetencyApplicabilities(modelAdapter
          .constructCompetencyApplicabilityFromListOfEntities(requestContext,
              competency.getCompetencyApplicabilityList(), configuredPaygradeMap,
              configuredJobFunctions));

      competencyModel.setRatingQuestionModels(
          findRatingQuestionsByCustomerIdAndCompetencyId(requestContext, competencyId));
      competencyModel.setTestSettingModel(
          findTestTemplateModelByCustomerIdAndCompetencyId(requestContext, competencyId));
      responseObject.setStatus(SUCCESS);
      responseObject.setResponseObject(competencyModel);
    }
    return responseObject;
  }

