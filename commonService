  @Override
  @Transactional
  public CompetencyMgmtResponseObject<CompetencyModel> upsertCompetency(
      RequestContext requestContext, CompetencyModel competencyModel) {
    log.info("Got the request to Upsert Competency. Request Context: {}, Competency Model: {}",
        requestContext, competencyModel);
    CompetencyMgmtResponseObject<CompetencyModel> responseObject =
        new CompetencyMgmtResponseObject<>(PROCESSING_ERROR);
    CompetencyManagementStatusCode responseCode = competencyModel.validate();
    if (SUCCESS.equals(responseCode)) {
      switch (competencyModel.getStatus()) {
        case ACTIVE:
          responseCode =
              publishCompetency(requestContext, competencyModel, responseObject);
          break;
        case DRAFT:
          responseCode =
              draftCompetency(requestContext, competencyModel, responseObject);
          break;
        default:
          log.debug("Invalid status: {} with RequestContext: {}, CompetencyModel: {}",
              competencyModel.getStatus(), requestContext, competencyModel);
          responseCode = DATA_VALIDATION_FAILED;
      }
    }
    responseObject.setStatus(responseCode);
    logResponseInDebug(responseObject.getResponseObject(), responseObject.getStatus());
    return responseObject;
  }

  private CompetencyManagementStatusCode draftCompetency(RequestContext requestContext,
      CompetencyModel competencyModel,
      CompetencyMgmtResponseObject<CompetencyModel> responseObject) {
    CompetencyManagementStatusCode responseCode = SUCCESS;
    List<Competency> competenciesWithSameName =
        competencyService.findByCustomerIdAndStatusNotAndCompetencyNameIgnoreCase(
            requestContext.getCustomerId(), CompetencyStatus.INACTIVE,
            competencyModel.getCompetencyName());

    Boolean competencyWithSameNameExists =
        isCompetencyWithSameNameExist(competenciesWithSameName, competencyModel);

    if (competencyWithSameNameExists) {
      log.info("There already is a competency with the same name: {}, hence not updating the "
          + "competency.", competencyModel.getCompetencyName());
      responseCode = DUPLICATE_COMPETENCY_NAME;
    } else {
      Competency competency = upsertCompetency(competencyModel, requestContext);
      if (CollectionUtils.isNotEmpty(competencyModel.getCompetencyApplicabilities())) {
        responseCode = ValidationUtility.getApplicabilityValidation(
            competencyModel.getCompetencyApplicabilities());
        upsertCompetencyApplicability(competency.getId(),
            competencyModel.getCompetencyApplicabilities(), requestContext);
      }
      competencyModel.setId(competency.getId());
      competencyModel.setCustomerId(requestContext.getCustomerId());
      responseObject.setResponseObject(competencyModel);
      TestSettingsModel testSettingsModel = upsertTestSetting(competencyModel);
      responseObject.getResponseObject().setTestSettingModel(testSettingsModel);
      upsertRatingQuestions(competencyModel, requestContext);
    }
    return responseCode;
  }

  private CompetencyManagementStatusCode publishCompetency(
      RequestContext requestContext, CompetencyModel competencyModel,
      CompetencyMgmtResponseObject<CompetencyModel> responseObject) {
    CompetencyManagementStatusCode responseCode = SUCCESS;
    if (Objects.isNull(competencyModel.getTestSettingModel()) && CollectionUtils.isEmpty(
        competencyModel.getRatingQuestionModels())) {
      responseCode = DATA_VALIDATION_FAILED;
      log.error("Competency Model Validation Failed. Response Code: {}", responseCode);
    }
    if (SUCCESS.equals(responseCode) && null != competencyModel.getTestSettingModel()) {
      responseCode = competencyModel.getTestSettingModel().validate();
      log.info("Test setting model Validation response : {}", responseCode);
    }
    if (SUCCESS.equals(responseCode)) {
      responseCode = ValidationUtility.getApplicabilityValidation(
          competencyModel.getCompetencyApplicabilities());
      log.info("Competency Applicability Validation Response : {}", responseCode);
    }
    if (SUCCESS.equals(responseCode)) {
      List<Competency> competenciesWithSameName =
          competencyService.findByCustomerIdAndStatusNotAndCompetencyNameIgnoreCase(
              requestContext.getCustomerId(), CompetencyStatus.INACTIVE,
              competencyModel.getCompetencyName());

      Boolean competencyWithSameNameExists =
          isCompetencyWithSameNameExist(competenciesWithSameName, competencyModel);

      if (competencyWithSameNameExists) {
        log.info("There already is a competency with the same name: {}, hence not updating the "
            + "competency.", competencyModel.getCompetencyName());
        responseCode = DUPLICATE_COMPETENCY_NAME;
      } else {
        Competency competency = upsertCompetency(competencyModel, requestContext);
        upsertCompetencyApplicability(competency.getId(),
            competencyModel.getCompetencyApplicabilities(), requestContext);
        competencyModel.setId(competency.getId());
        competencyModel.setCustomerId(requestContext.getCustomerId());
        responseObject.setResponseObject(competencyModel);
        TestSettingsModel testSettingsModel = upsertTestSetting(competencyModel);
        responseObject.getResponseObject().setTestSettingModel(testSettingsModel);
        upsertRatingQuestions(competencyModel, requestContext);
      }
    }
    return responseCode;
  }

  private Boolean isCompetencyWithSameNameExist(List<Competency> competenciesWithSameName,
      CompetencyModel competencyModel) {
    Boolean competencyWithSameNameExists = Boolean.FALSE;
    if (CollectionUtils.isNotEmpty(competenciesWithSameName)) {
      if (null == competencyModel.getId()) {
        competencyWithSameNameExists = Boolean.TRUE;
      } else {
        for (Competency competency : competenciesWithSameName) {
          if (!competencyModel.getId().equals(competency.getId())) {
            competencyWithSameNameExists = Boolean.TRUE;
            break;
          }
        }
      }
    }
    return competencyWithSameNameExists;
  }

