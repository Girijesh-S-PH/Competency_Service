  @Override
  public CompetencyMgmtResponseObject<AssignCompetencyModel> assignPayGradeAndJobFunctionToCompetencies(
      RequestContext requestContext, AssignCompetencyModel assignCompetencyModel) {
    Set<Long> competencyIds = new HashSet<>();
    CompetencyMgmtResponseObject<AssignCompetencyModel> responseObject =
        new CompetencyMgmtResponseObject<>();
    Long mappedValue =
        genericUtility.mapUnassignedValueToAll(assignCompetencyModel.getPayGradeId());
    assignCompetencyModel.setPayGradeId(mappedValue);
    mappedValue = genericUtility.mapUnassignedValueToAll(assignCompetencyModel.getJobFunctionId());
    assignCompetencyModel.setJobFunctionId(mappedValue);
    List<CompetencyApplicability> competencyApplicabilityToSave = new ArrayList<>();
    List<CompetencyPaygrade> competencyPaygradesToSave = new ArrayList<>();
    CompetencyManagementStatusCode statusCode;
    assignCompetencyModel.getAssignedCompetencies().forEach(assignedCompetency -> {
      competencyIds.add(assignedCompetency.getCompetencyId());
    });
    if (competencyIds.size() != assignCompetencyModel.getAssignedCompetencies().size()) {
      statusCode = DUPLICATE_COMPETENCY;
    } else {
      List<CompetencyApplicability> competencyApplicabilities = competencyApplicabilityService
          .findByCustomerIdAndCompetencyIdIn(requestContext.getSignedInCustomerId(), competencyIds);
      statusCode = validateAssignCompetencyModel(requestContext, competencyApplicabilities,
          assignCompetencyModel);
    }
    if (SUCCESS.equals(statusCode)) {
      constructCompetencyAndApplicability(assignCompetencyModel, requestContext,
          competencyApplicabilityToSave, competencyPaygradesToSave);
      responseObject.setResponseObject(assignCompetencyModel);
      if (CollectionUtils.isNotEmpty(competencyApplicabilityToSave)) {
        competencyApplicabilityService.saveAll(competencyApplicabilityToSave);
        for (Integer itr = 0; itr < competencyApplicabilityToSave.size(); itr++) {
          competencyPaygradesToSave.get(itr)
              .setCompetencyApplicabilityId(competencyApplicabilityToSave.get(itr).getId());
        }
        competencyPaygradeService.saveAll(competencyPaygradesToSave);
      }
    }
    responseObject.setStatus(statusCode);
    return responseObject;
  }

  /**
   * method to delete competency based on below params
   *
   * @param requestContext
   * @param competencyId
   * @param forceDelete
   *
   * @return
   */
  @Transactional
  @Override
  public CompetencyMgmtResponseObject<Boolean> deleteCompetency(RequestContext requestContext,
      Long competencyId, boolean forceDelete) {
    log.info("CommonCompetencyServiceImpl: Request to deleteCompetency with requestContext: {}, "
        + "competencyId: {} and forceDelete: {}", requestContext, competencyId, forceDelete);
    CompetencyMgmtResponseObject<Boolean> responseObject = new CompetencyMgmtResponseObject<>();
    Competency competency =
        competencyService.findByCustomerIdAndId(requestContext.getCustomerId(), competencyId);
    if (Objects.nonNull(competency)) {
      VelocityContext velocityContext = new VelocityContext();
      velocityContext.put(COMPETENCY_ID, String.valueOf(competencyId));
      Boolean isLinked =
          computeLayerUtility.checkIfCompetencyIsLinkedToCycle(requestContext.getCustomerId(),
              competencyId);
      if (!isLinked || forceDelete) {
        competencyService.inactivateCompetency(requestContext.getCustomerId(), competencyId);
        responseObject.setResponseObject(Boolean.TRUE);
        responseObject.setStatus(CompetencyManagementStatusCode.SUCCESS);
      } else {
        log.debug("found cycles linked with competencyId: {}, " + "requestContext: {}",
            competencyId, requestContext);
        responseObject.setResponseObject(Boolean.FALSE);
        responseObject.setStatus(CompetencyManagementStatusCode.COMPETENCY_ALREADY_IN_USE);
      }
    } else {
      log.error("Could not find competency with competencyId: {}, requestContext: {} and "
          + "responseObject: {}", responseObject, requestContext, competencyId);
      throw new CompetencyMgmtException(PROCESSING_ERROR);
    }
    return responseObject;
  }

