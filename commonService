  @Override
  public CompetencyMgmtResponseObject<Long> deleteByCustomerIdAndId(RequestContext requestContext,
      Long groupId) {
    CompetencyMgmtResponseObject<Long> responseObject =
        new CompetencyMgmtResponseObject<>(PROCESSING_ERROR);
    log.info("Got the request to Delete Group By CustomerId: {} And Id: {}", requestContext,
        groupId);
    CompetencyGroup group =
        competencyGroupService.findByCustomerIdAndId(requestContext.getCustomerId(), groupId);
    if (!Objects.isNull(group)) {
      List<Competency> linkedCompetency = competencyService
          .findByCustomerIdAndCompetencyGroupId(requestContext.getCustomerId(), groupId);
      log.info("There are a few Competencies: {} associated with the provided group.",
          linkedCompetency);
      if (CollectionUtils.isNotEmpty(linkedCompetency)) {
        responseObject.setStatus(GROUP_NAME_IN_USE);
      } else {
        log.debug("Successfully deleted the competency group with id: {}", groupId);
        responseObject.setStatus(SUCCESS);
        competencyGroupService.deleteCompetencyGroup(group);
      }
    } else {
      log.error("No Competency Group found for the Customer: {}, Group Id: {}", requestContext,
          groupId);
      responseObject.setStatus(DATA_VALIDATION_FAILED);
    }
    logResponseInDebug(responseObject.getResponseObject(), responseObject.getStatus());
    return responseObject;
  }

  @Override
  public CompetencyMgmtResponseObject<Page<CompetencyModel>> findPageableCompetencyListForCustomer(
      RequestContext requestContext, SearchFilter searchFilter, Pageable pageable) {
    CompetencyMgmtResponseObject<Page<CompetencyModel>> responseObject =
        new CompetencyMgmtResponseObject<>(PROCESSING_ERROR);
    log.info(
        "Got the request to get Pageable Competency List for the Customer. Request Context: {}, "
            + "Search Filter: {}, "
            + "Page Request: {}", requestContext, searchFilter, pageable);
    UserModel loggedInUserModel =
        onboardingRestUtility.getBasicUserInfo(requestContext, requestContext.getSignedInUserId());
    String timeZone =
        (null == loggedInUserModel) ? StringUtils.EMPTY : loggedInUserModel.getTimeZone();
    searchFilter.setUpdatedOnFrom(requestContextUtility
        .convertLongToTimeForFilter(searchFilter.getUpdatedOnFromLong(), true, timeZone));
    searchFilter.setUpdatedOnTo(requestContextUtility
        .convertLongToTimeForFilter(searchFilter.getUpdatedOnToLong(), false, timeZone));
    Page<Competency> competencyPage = competencyService
        .findAllByCustomerId(requestContext.getCustomerId(), searchFilter, pageable);
    List<CompetencyModel> competencies = new ArrayList<>();
    if (null != competencyPage && competencyPage.getTotalElements() > 0) {
      Map<Long, BasicIdentityModel> userModelMap = new HashMap<>();
      Map<Long, CompetencyGroup> competencyGroupMap =
          getCompetencyGroupsForCustomer(requestContext);
      Map<Long, PayGradeModel> payGradeModelMap = getPayGradeConfiguredForCustomer(requestContext);
      Map<Long, JobFunction> configuredJobFunctions = getJobFunctionsForCustomer(requestContext);
      log.debug(
          "Competencies found : {}, Competency Groups: {}, Configured Paygrades: {}, Configured "
              + "Job Functions: {}",
          competencyPage, competencyGroupMap, payGradeModelMap, configuredJobFunctions);
      competencyPage.getContent().forEach(competency -> {
        CompetencyModel competencyModel =
            modelAdapter.getBasicCompetencyModelFromEntity(competency);
        Long userId = competency.getUpdatedBy();
        if (!userModelMap.containsKey(userId)) {
          userModelMap.put(userId, new BasicIdentityModel());
        }
        competencyModel.setModifiedBy(userModelMap.get(userId));
        Long groupId = competency.getCompetencyGroupId();
        if (competencyGroupMap.containsKey(groupId)) {
          competencyModel.setCompetencyGroupName(competencyGroupMap.get(groupId).getGroupName());
        }

        List<CompetencyApplicability> competencyApplicabilityList =
            competency.getCompetencyApplicabilityList();
        if (CollectionUtils.isNotEmpty(competencyApplicabilityList)) {
          competencyModel.setCompetencyApplicabilities(modelAdapter
              .constructCompetencyApplicabilityFromListOfEntities(requestContext,
                  competencyApplicabilityList, payGradeModelMap, configuredJobFunctions));
        }
        competencies.add(competencyModel);
      });

      if (MapUtils.isNotEmpty(userModelMap)) {
        List<UserModel> userModelList = onboardingRestUtility
            .getBasicUserInfoList(requestContext, new ArrayList<>(userModelMap.keySet()),
                Boolean.TRUE);

        if (CollectionUtils.isNotEmpty(userModelList)) {
          for (UserModel userModel : userModelList) {
            BasicIdentityModel identityModel = userModelMap.get(userModel.getUserId());
            genericUtility.setBasicIdentityModel(identityModel, userModel);
          }
        }
      }
    }
    responseObject.setResponseObject(new PageImpl<>(competencies, pageable,
        null == competencyPage ? 0 : competencyPage.getTotalElements()));
    responseObject.setStatus(SUCCESS);
    logResponseInDebug(responseObject.getResponseObject(), responseObject.getStatus());
    return responseObject;
  }

  private Map<Long, CompetencyGroup> getCompetencyGroupsForCustomer(RequestContext requestContext) {
    log.info("Getting the Competency Groups for Customer. Request Context: {}", requestContext);
    Map<Long, CompetencyGroup> responseMap = new HashMap<>();
    List<CompetencyGroup> competencyGroups =
        competencyGroupService.findAllByCustomerId(requestContext.getCustomerId());
    if (CollectionUtils.isNotEmpty(competencyGroups)) {
      competencyGroups
          .forEach(competencyGroup -> responseMap.put(competencyGroup.getId(), competencyGroup));
    }
    logResponseInDebug(responseMap, SUCCESS);
    return responseMap;
  }

  private Map<Long, PayGradeModel> getPayGradeConfiguredForCustomer(RequestContext requestContext) {
    log.info("getting the Configured Paygrade for Customer. {}", requestContext);
    Map<Long, PayGradeModel> returnMap = new HashMap<>();
    List<PayGradeModel> payGradeModels = financeRestUtility.getPayGradeForCustomer(requestContext);
    if (CollectionUtils.isNotEmpty(payGradeModels)) {
      payGradeModels.forEach(payGradeModel -> returnMap.put(payGradeModel.getId(), payGradeModel));
    }
    returnMap.put(LONG_ZERO, new PayGradeModel(LONG_ZERO, GenericConstant.PAYGRADE_ALL, null));
    logResponseInDebug(returnMap, SUCCESS);
    return returnMap;
  }

