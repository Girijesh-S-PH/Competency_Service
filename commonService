  @Override
  public CompetencyMgmtResponseObject<List<CompetencyGroupModel>> findAllByCompetencyGroupCustomerId(
      Long customerId) {
    log.info("Getting list of Competency Group. CustomerId: {}", customerId);
    CompetencyMgmtResponseObject<List<CompetencyGroupModel>> responseObject =
